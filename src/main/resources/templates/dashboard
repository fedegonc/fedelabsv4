<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Panel CrossFit</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f4f4f2; color: #1a1a1a; min-height: 100vh; padding: 2rem; }
  .dash { max-width: 860px; margin: 0 auto; }
  .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  .header h1 { font-size: 20px; font-weight: 600; }
  .header p { font-size: 13px; color: #888; margin-top: 3px; }
  .badge { font-size: 11px; padding: 5px 12px; border-radius: 8px; background: #d1fae5; color: #065f46; font-weight: 600; }
  .metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 1.25rem; }
  .metric { background: #fff; border-radius: 10px; padding: 16px 18px; border: 1px solid #e8e8e4; }
  .metric-label { font-size: 12px; color: #888; margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
  .metric-value { font-size: 28px; font-weight: 600; line-height: 1; }
  .metric-sub { font-size: 12px; color: #059669; margin-top: 5px; }
  .metric-sub.warn { color: #d97706; }
  .row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 1.25rem; }
  .card { background: #fff; border: 1px solid #e8e8e4; border-radius: 12px; padding: 1.1rem 1.25rem; }
  .card-title { font-size: 11px; font-weight: 600; color: #aaa; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.06em; }
  .bars { display: flex; align-items: flex-end; gap: 6px; height: 110px; }
  .bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .bar { width: 100%; border-radius: 4px 4px 0 0; }
  .bar-label { font-size: 11px; color: #aaa; }
  .bar-val { font-size: 11px; color: #444; font-weight: 600; }
  .donut-wrap { display: flex; align-items: center; gap: 20px; }
  .legend { display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .legend-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #333; }
  .dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .legend-pct { font-size: 12px; color: #aaa; margin-left: auto; }
  .table-card { background: #fff; border: 1px solid #e8e8e4; border-radius: 12px; padding: 1.1rem 1.25rem; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { text-align: left; font-weight: 600; font-size: 11px; color: #aaa; padding: 0 0 10px; text-transform: uppercase; letter-spacing: 0.05em; }
  td { padding: 8px 0; border-top: 1px solid #f0f0ee; color: #1a1a1a; }
  .status { display: inline-block; font-size: 11px; padding: 3px 9px; border-radius: 6px; font-weight: 600; }
  .s-ok  { background: #d1fae5; color: #065f46; }
  .s-warn{ background: #fef3c7; color: #92400e; }
  .s-bad { background: #fee2e2; color: #991b1b; }
  .mini-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-top: 1px solid #f0f0ee; font-size: 13px; }
  .mini-row:first-child { border-top: none; padding-top: 0; }
  .class-name { font-weight: 600; color: #1a1a1a; }
  .class-time { font-size: 12px; color: #aaa; margin-top: 1px; }
  .avail { color: #059669; font-size: 12px; font-weight: 600; }
  .full  { color: #dc2626; font-size: 12px; font-weight: 600; }

  @media (max-width: 600px) {
    body { padding: 1rem; }
    .metrics { grid-template-columns: repeat(2, 1fr); }
    .row { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>
<div class="dash">

  <div class="header">
    <div>
      <h1>CrossFit Rivera <i class="ti ti-barbell" style="font-size:16px; vertical-align:-1px;"></i></h1>
      <p>Mayo 2025</p>
    </div>
    <span class="badge">● En vivo</span>
  </div>

  <div class="metrics">
    <div class="metric">
      <div class="metric-label"><i class="ti ti-users" style="font-size:14px;"></i> Socios activos</div>
      <div class="metric-value">87</div>
      <div class="metric-sub">↑ 6 este mes</div>
    </div>
    <div class="metric">
      <div class="metric-label"><i class="ti ti-currency-dollar" style="font-size:14px;"></i> Ingresos mayo</div>
      <div class="metric-value">$142k</div>
      <div class="metric-sub">↑ 12% vs abril</div>
    </div>
    <div class="metric">
      <div class="metric-label"><i class="ti ti-run" style="font-size:14px;"></i> Asistencia prom.</div>
      <div class="metric-value">14</div>
      <div class="metric-sub">por clase / día</div>
    </div>
    <div class="metric">
      <div class="metric-label"><i class="ti ti-alert-circle" style="font-size:14px;"></i> Cuotas vencidas</div>
      <div class="metric-value">9</div>
      <div class="metric-sub warn">↑ 3 sin contactar</div>
    </div>
  </div>

  <div class="row">
    <div class="card">
      <div class="card-title">Asistencia por día</div>
      <div class="bars" id="bars"></div>
    </div>
    <div class="card">
      <div class="card-title">Tipos de membresía</div>
      <div class="donut-wrap">
        <svg width="90" height="90" viewBox="0 0 90 90">
          <circle cx="45" cy="45" r="34" fill="none" stroke="#1D9E75" stroke-width="14" stroke-dasharray="107 107" stroke-dashoffset="0" transform="rotate(-90 45 45)"/>
          <circle cx="45" cy="45" r="34" fill="none" stroke="#378ADD" stroke-width="14" stroke-dasharray="64 214" stroke-dashoffset="-107" transform="rotate(-90 45 45)"/>
          <circle cx="45" cy="45" r="34" fill="none" stroke="#BA7517" stroke-width="14" stroke-dasharray="43 214" stroke-dashoffset="-171" transform="rotate(-90 45 45)"/>
          <text x="45" y="49" text-anchor="middle" font-size="14" font-weight="600" fill="#1a1a1a">87</text>
        </svg>
        <div class="legend">
          <div class="legend-item"><span class="dot" style="background:#1D9E75"></span>Mensual<span class="legend-pct">50%</span></div>
          <div class="legend-item"><span class="dot" style="background:#378ADD"></span>Trimestral<span class="legend-pct">30%</span></div>
          <div class="legend-item"><span class="dot" style="background:#BA7517"></span>Anual<span class="legend-pct">20%</span></div>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="table-card">
      <div class="card-title">Cuotas vencidas</div>
      <table>
        <thead><tr><th>Socio</th><th>Vence</th><th>Estado</th></tr></thead>
        <tbody>
          <tr><td>Martín F.</td><td>10 may</td><td><span class="status s-bad">Vencida</span></td></tr>
          <tr><td>Valentina R.</td><td>12 may</td><td><span class="status s-bad">Vencida</span></td></tr>
          <tr><td>Lucas P.</td><td>18 may</td><td><span class="status s-warn">Por vencer</span></td></tr>
          <tr><td>Camila S.</td><td>21 may</td><td><span class="status s-warn">Por vencer</span></td></tr>
          <tr><td>Diego M.</td><td>15 abr</td><td><span class="status s-bad">Vencida</span></td></tr>
        </tbody>
      </table>
    </div>
    <div class="table-card">
      <div class="card-title">Clases de hoy</div>
      <div id="classes"></div>
    </div>
  </div>

</div>

<script>
  const days = ['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'];
  const vals = [18, 22, 16, 24, 21, 14, 8];
  const max = Math.max(...vals);
  const colors = ['#1D9E75','#1D9E75','#1D9E75','#1D9E75','#1D9E75','#378ADD','#ccc'];
  const barsEl = document.getElementById('bars');
  days.forEach((d, i) => {
    const h = Math.round((vals[i] / max) * 95);
    barsEl.innerHTML += `<div class="bar-wrap">
      <div class="bar-val">${vals[i]}</div>
      <div class="bar" style="height:${h}px;background:${colors[i]};"></div>
      <div class="bar-label">${d}</div>
    </div>`;
  });

  const classes = [
    { name: 'WOD Mañana',   time: '07:00', spots: '18/20', avail: true  },
    { name: 'WOD Mediodía', time: '12:30', spots: '12/20', avail: true  },
    { name: 'Weightlifting',time: '17:00', spots: '20/20', avail: false },
    { name: 'WOD Tarde',    time: '19:00', spots: '7/20',  avail: true  },
  ];
  const cl = document.getElementById('classes');
  classes.forEach(c => {
    cl.innerHTML += `<div class="mini-row">
      <div>
        <div class="class-name">${c.name}</div>
        <div class="class-time">${c.time} hs</div>
      </div>
      <div class="${c.avail ? 'avail' : 'full'}">${c.spots} ${c.avail ? '✓' : '● llena'}</div>
    </div>`;
  });
</script>
</body>
</html>
